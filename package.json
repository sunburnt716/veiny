{
  "name": "veiny",
  "version": "1.0.0",
  "description": "A CLI developer tool that maps a codebase into a dependency graph and analyzes staged git diffs — deterministic type-check + blast radius, plus an optional provider-agnostic LLM risk report — before commits land.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "veiny": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "tsx src/index.ts",
    "veiny": "tsx src/index.ts",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "cli",
    "dependency-graph",
    "static-analysis",
    "git",
    "pre-commit",
    "typescript",
    "ast",
    "babel",
    "llm",
    "developer-tools"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sunburnt716/veiny.git"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/sunburnt716/veiny/issues"
  },
  "homepage": "https://github.com/sunburnt716/veiny#readme",
  "devDependencies": {
    "@types/babel__traverse": "^7.28.0",
    "@types/node": "^24.0.10",
    "tsx": "^4.20.5",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@babel/parser": "^7.29.7",
    "@babel/traverse": "^7.29.7",
    "typescript": "^6.0.3"
  }
}
